{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "ignoreDeprecations": "6.0",
    "types": ["react-native-dotenv", "node"]   // ← Add "node" too if needed
  },
  "include": [
    "src/**/*",
    "App.tsx",
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "src/types/env.d.ts"     // ← Make sure this is included
  ],
  "exclude": [
    "node_modules",
    "android",
    "ios"
  ]
}